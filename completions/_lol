#compdef lol

# Zsh completion for lol — https://github.com/thephilip/lol
# Install: lol completion zsh > ~/.zfunc/_lol
# Then ensure ~/.zfunc is in your fpath (before compinit):
#   fpath=(~/.zfunc $fpath)

_lol() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help and exit]' \
    '(-v --version)'{-v,--version}'[show version and exit]' \
    '--context[named context to create or use]:context name:_lol_contexts' \
    '1: :_lol_commands' \
    '*:: :->args'

  case $state in
    args)
      case $line[1] in
        use)
          _arguments \
            '1:must-gather path:_files -/'
          ;;
        check)
          _arguments \
            '--no-log[do not record this run to the context ledger]' \
            '--with-clankers[run local AI analysis against the must-gather]:query' \
            '--clankers-model[model to use for AI analysis]:model name' \
            '*:check name:_lol_check_names'
          ;;
        context)
          local -a ctx_subcmds
          ctx_subcmds=(
            'new:create and activate a new empty context'
            'list:list all saved contexts'
            'resume:resume a saved context'
            'show:show details of a context'
            'rm:delete a saved context'
          )
          _arguments \
            '1: :->ctx_sub' \
            '*:: :->ctx_args'
          case $state in
            ctx_sub)  _describe 'subcommand' ctx_subcmds ;;
            ctx_args)
              case $line[1] in
                resume|show|rm) _arguments '1:context name:_lol_contexts' ;;
              esac
              ;;
          esac
          ;;
        ready-up)
          _arguments \
            '--no-redact[skip PII scrubbing (for internal/self-hosted AI only)]' \
            '(-o --output)'{-o,--output}'[write to file instead of stdout]:output file:_files' \
            '--with-skills[prepend CLI skill docs (all skills, or comma-separated names)]:skills (e.g. omc,ocm)'
          ;;
        service-log)
          _arguments \
            '--no-log[do not record this run to the context ledger]' \
            '--size[number of entries to fetch (default\: 20)]:count'
          ;;
        alerts)
          _arguments \
            '--no-log[do not record this run to the context ledger]' \
            '--all[include inactive alerts (default: firing and pending only)]'
          ;;
        limited-support|addons)
          _arguments \
            '--no-log[do not record this run to the context ledger]'
          ;;
        get|describe|logs|extract|adm|projects|top|whoami)
          _arguments \
            '--no-log[do not record this run to the context ledger]' \
            '*: :_default'
          ;;
        cluster)
          _arguments \
            '(-C --cluster)'{-C,--cluster}'[set active cluster via OCM]:cluster ID or name'
          ;;
        findings)
          local -a findings_subcmds
          findings_subcmds=(
            'show:print the findings log for the active context'
            'clear:remove the findings log for the active context'
            'edit:open the findings log in \$EDITOR'
          )
          _arguments '1: :->findings_sub'
          case $state in
            findings_sub) _describe 'subcommand' findings_subcmds ;;
          esac
          ;;
        ask)
          _arguments \
            '--no-log[do not record this session to the context ledger]' \
            '*:question'
          ;;
        list|status|upgrade|reset|version|config) ;;
      esac
      ;;
  esac
}

_lol_commands() {
  local -a commands
  commands=(
    'use:set the active must-gather'
    'check:run checks against the active must-gather'
    'cluster:show cluster summary (version, platform, network)'
    'context:manage named contexts (list / resume / show)'
    'findings:view or manage the AI investigation findings log'
    'ready-up:generate an AI-ready handoff document'
    'list:list available checks'
    'status:show active session and context info'
    'upgrade:pull the latest version from origin/main'
    'ask:AI chat with omc/ocm skills and cluster context (no arg = interactive)'
    'config:interactive configuration menu (AI model, endpoint)'
    'reset:remove all lol session data and return to factory state'
    'version:show version, commit, and available releases'
    'alerts:fetch live alerts from OCM'
    'service-log:fetch service log entries from OCM'
    'limited-support:check for limited support reasons via OCM'
    'addons:list installed addons and their state via OCM'
    'get:get resources (omc from must-gather, or live oc)'
    'describe:describe a resource (omc from must-gather, or live oc)'
    'logs:view pod logs (omc from must-gather, or live oc)'
    'top:show node/pod resource usage'
    'projects:list projects'
    'whoami:show current oc login (live cluster only)'
    'extract:omc only — extract must-gather data'
    'adm:cluster administration commands'
  )
  _describe 'command' commands
}

# Dynamically complete saved context names from ~/.config/lol/contexts/
_lol_contexts() {
  local config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/lol/contexts"
  local -a names
  if [[ -d "$config_dir" ]]; then
    local dir
    for dir in "$config_dir"/*/; do
      [[ -f "${dir}meta.env" ]] && names+=("${dir%/}")
    done
    names=("${names[@]##*/}")
  fi
  _describe 'context name' names
}

# Dynamically complete check names from the lol install's checks/ directory
_lol_check_names() {
  local lol_bin real_lol checks_dir
  lol_bin="$(command -v lol 2>/dev/null)"
  if [[ -n "$lol_bin" ]]; then
    real_lol="$(readlink -f "$lol_bin" 2>/dev/null || echo "$lol_bin")"
    checks_dir="$(dirname "$real_lol")/checks"
  fi
  local -a names
  if [[ -d "$checks_dir" ]]; then
    names=("${checks_dir}"/*.sh)
    names=("${names[@]##*/}")
    names=("${names[@]%.sh}")
    _describe 'check name' names
  fi
}

_lol "$@"
